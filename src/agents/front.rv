// Frontmatter parsing shared by every .agents file kind (skills, commands,
// subagents): "key: value" lines between two "---" lines, then a markdown
// body. A file without frontmatter is all body. Values may be quoted; the
// quotes are stripped.

import std/string

struct Front {
    keys: List<String>,
    values: List<String>,
    body: String,
}

fun parse_front(text: String) -> Front {
    let keys: List<String> = []
    let values: List<String> = []
    let body = text
    let lines = text.lines()
    if lines.len() > 0 && lines[0].trim() == "---" {
        let i = 1
        let closed = 0 - 1
        while i < lines.len() {
            let t = lines[i].trim()
            if t == "---" {
                closed = i
                break
            }
            let colon = t.index_of(":")
            if colon > 0 {
                keys.push(t.substring(0, colon).trim())
                values.push(_unquote(t.substring(colon + 1, t.length()).trim()))
            }
            i = i + 1
        }
        if closed >= 0 {
            body = _join_from(lines, closed + 1)
        }
    }
    return Front { keys, values, body: body.trim() }
}

// The value of `key`, "" when the frontmatter does not carry it.
fun front_get(f: Front, key: String) -> String {
    let i = 0
    while i < f.keys.len() {
        if f.keys[i] == key {
            return f.values[i]
        }
        i = i + 1
    }
    return ""
}

fun _unquote(v: String) -> String {
    if v.length() >= 2 && v.starts_with("\"") && v.ends_with("\"") {
        return v.substring(1, v.length() - 1)
    }
    return v
}

fun _join_from(lines: List<String>, start: Int) -> String {
    let out = ""
    let i = start
    while i < lines.len() {
        if i > start {
            out = out.concat("\n")
        }
        out = out.concat(lines[i])
        i = i + 1
    }
    return out
}
